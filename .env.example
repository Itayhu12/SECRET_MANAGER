# ─────────────────────────────────────────────
#  Secure Secrets Manager — Environment Config
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Flask core
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=app.py

# Secret key for Flask session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-random-hex-string

# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=change-me-generate-a-different-random-hex-string

# JWT token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Fernet encryption key for secrets at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-with-fernet

# File storage root (relative to project root)
STORAGE_PATH=storage

# Share link default TTL in seconds (3600 = 1 hour)
SHARE_DEFAULT_TTL_SECONDS=3600
SHARE_MAX_TTL_SECONDS=86400
